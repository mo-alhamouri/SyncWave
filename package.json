{
  "name": "syncwave-desktop",
  "version": "1.0.8",
  "main": "electron/main.js",
  "scripts": {
    "setup": "npm install && npm run setup:backend && npm run setup:frontend",
    "setup:backend": "npm install --prefix backend",
    "setup:frontend": "npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently --kill-others \"npm run dev:frontend\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "build:frontend": "npm run build --prefix frontend",
    "dist": "npm run build:frontend && electron-builder",
    "deploy": "gh-pages -d \"Marketing Website\""
  },
  "build": {
    "appId": "com.syncwave.app",
    "productName": "SyncWave",
    "publish": [
      {
        "provider": "github",
        "owner": "mo-alhamouri",
        "repo": "SyncWave"
      }
    ],
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*",
      "!backend/downloads/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "gh-pages": "^6.3.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.1.7",
    "fix-path": "^3.0.0",
    "uuid": "^14.0.0",
    "yt-dlp-wrap": "^2.3.12"
  }
}
